# Environment variables for running the application

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (if using PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Admin Credentials (for admin dashboard)
# REQUIRED: Set these to secure values before deploying
ADMIN_USER=your_admin_email@example.com
ADMIN_PASS=your_secure_password_here

# JWT Secret (for authentication)
# REQUIRED: Use a strong random secret (minimum 32 characters in production)
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_required_in_production

# Optional: API Keys (if needed)
# OPENAI_API_KEY=your_api_key_here
# ELEVENLABS_API_KEY=your_api_key_here

# Optional: Cloud Storage (if needed)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=your_bucket_name